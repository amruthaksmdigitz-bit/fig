  .d-inline-block.d-xl-none .site-menu-toggle {
    font-size: 1.5rem;
    padding: 12px;
}

.d-inline-block.d-xl-none .icon-menu {
    font-size: 2rem;
}
  .d-inline-block.d-xl-none {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
}
.site-navbar .row.align-items-center {
