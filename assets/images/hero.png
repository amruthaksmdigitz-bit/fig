  /* Sticky Header Styles */
.site-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 9999;
    background: #fff;
   /* backdrop-filter: blur(10px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);*/
    transition: all 0.3s ease;
}

/* Optional: Add background when scrolled */
.site-navbar.scrolled {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 2px 30px rgba(0, 0, 0, 0.15);
}



/* Logo adjustment for sticky header */
.site-navbar .site-logo img {
    transition: all 0.3s ease;
    max-height: 85px;
}

.site-navbar.scrolled .site-logo img {
    max-height: 40px; /* Smaller logo when scrolled */
}
    /* WhatsApp Floating Icon */
    .whatsapp-float {
      position: fixed;
      left: 30px;
      bottom: 30px;
      z-index: 9999;
      background: #25D366;
      color: #fff;
      border-radius: 50%;
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      box-shadow: 0 4px 18px rgba(0, 0, 0, .10);
      transition: box-shadow .2s, background .2s;
    }

    .whatsapp-float:hover {
      background: #128C7E;
      box-shadow: 0 8px 28px rgba(0, 0, 0, .16);
      color: #fff;
    }

    .whatsapp-float .icon-whatsapp {
      font-size: 2.3rem;
    }
    .text-theme
    {
             color: #DDB15A !important;
    }
